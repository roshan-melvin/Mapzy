<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base layer: deep purple (bottom-left) to sky blue (top-right) -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:startColor="#3B1578"
                android:centerColor="#E8395A"
                android:endColor="#0EADDD"
                android:angle="45"/>
        </shape>
    </item>

    <!-- Mid layer: hot pink/magenta to warm orange, semi-transparent overlay -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:startColor="#99D41876"
                android:centerColor="#99F5603C"
                android:endColor="#4400B4D8"
                android:angle="30"/>
        </shape>
    </item>

    <!-- Top layer: coral-orange wave highlight across the center -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:startColor="#66F79D3D"
                android:centerColor="#33F54E5E"
                android:endColor="#00000000"
                android:gradientRadius="60%"
                android:centerX="0.6"
                android:centerY="0.4"/>
        </shape>
    </item>

</layer-list>
