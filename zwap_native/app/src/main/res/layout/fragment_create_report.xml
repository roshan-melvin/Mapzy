<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mapzy_black"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Report an Issue"
            android:textColor="@color/premium_text_main"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="28dp"
            android:layout_marginTop="8dp"/>

        <!-- CHANNEL label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CHANNEL"
            android:textColor="@color/premium_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <AutoCompleteTextView
            android:id="@+id/et_hashtag_channel"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_report_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:hint="#accident, #construction, etc."
            android:text="#"
            android:textColor="@color/premium_text_main"
            android:textColorHint="@color/premium_text_secondary"
            android:textSize="15sp"
            android:dropDownHeight="wrap_content"
            android:layout_marginBottom="20dp"/>

        <!-- Most Popular Tags -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Most Popular"
                android:textColor="#B9BBBE"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#3E4047"/>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="16dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_popular_tags"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true"
                app:chipSpacingHorizontal="6dp"/>
        </HorizontalScrollView>

        <!-- DESCRIPTION label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DESCRIPTION"
            android:textColor="@color/premium_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>


        <EditText
            android:id="@+id/et_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_report_input"
            android:minHeight="120dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:gravity="top|start"
            android:hint="Describe what happened..."
            android:textColor="@color/premium_text_main"
            android:textColorHint="@color/premium_text_secondary"
            android:textSize="15sp"
            android:inputType="textMultiLine"
            android:layout_marginBottom="8dp"/>

        <!-- Smart Suggestions Chip Group -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="16dp">
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_suggestions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true"/>
        </HorizontalScrollView>

        <!-- LOCATION label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOCATION"
            android:textColor="@color/premium_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <!-- Map Preview -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_report_card">

            <com.mappls.sdk.maps.MapView
                android:id="@+id/map_pick_location"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <!-- Center Pinpoint Marker -->
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_mylocation"
                android:tint="#F44336"
                android:layout_marginBottom="20dp"/>

            <!-- Coordinate Display Overlay -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:background="#CC1C1C1E"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tv_location_preview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lat: 0.000000, Lng: 0.000000"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drag map to position pinpoint"
                    android:textColor="#AAAAAA"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </FrameLayout>

        <!-- PROOF label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROOF"
            android:textColor="@color/premium_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>
        
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            
            <ImageView
                android:id="@+id/iv_media_preview"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@color/premium_surface"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_camera_outlined"/>
                
            <VideoView
                android:id="@+id/vv_media_preview"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:visibility="gone"/>
                
            <ImageView
                 android:id="@+id/iv_play_preview"
                 android:layout_width="48dp"
                 android:layout_height="48dp"
                 android:src="@android:drawable/ic_media_play"
                 android:layout_gravity="center"
                 android:visibility="gone"/>
        </FrameLayout>

        <Button
            android:id="@+id/btn_upload_media"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Attach Media"
            android:textColor="@color/premium_text_main"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_report_button_secondary"
            android:stateListAnimator="@null"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btn_submit_report"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Submit Report"
            android:textColor="@color/mapzy_black"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_report_button_primary"
            android:stateListAnimator="@null"/>

            
        <ProgressBar
            android:id="@+id/pb_uploading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginTop="16dp"/>

    </LinearLayout>
</ScrollView>
