<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2F3136"
    android:clickable="true"
    android:focusable="true">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/thread_header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#36393F"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btn_thread_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#B9BBBE"
            android:layout_marginEnd="16dp"/>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/stat_notify_chat"
            app:tint="#B9BBBE"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thread"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"/>
    </LinearLayout>

    <!-- Bottom Input -->
    <LinearLayout
        android:id="@+id/thread_input_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="12dp"
        android:background="#36393F"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_add"
            app:tint="#B9BBBE"
            android:layout_marginEnd="12dp"
            android:background="@drawable/circle_bg"
            android:padding="4dp"/>

        <EditText
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/rounded_border_bg"
            android:backgroundTint="#40444B"
            android:hint="Message in thread"
            android:textColorHint="#72767D"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:textSize="14sp"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_send"
            app:tint="#B9BBBE"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <!-- Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/thread_header"
        android:layout_above="@id/thread_input_area"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Original Post Preview -->
            <include layout="@layout/item_report_card"
                android:id="@+id/thread_original_post"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#40444B"
                android:layout_marginVertical="16dp"/>

            <!-- Map Preview -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOCATION PREVIEW"
                android:textColor="#B9BBBE"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <com.mappls.sdk.maps.MapView
                android:id="@+id/thread_map_preview"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="#202225"/>
            
            <TextView
                android:id="@+id/tv_exact_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lat: 13.0045, Lon: 80.2013"
                android:textColor="#B9BBBE"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#40444B"
                android:layout_marginVertical="16dp"/>

            <!-- Comments -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMMENTS"
                android:textColor="#B9BBBE"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_comments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</RelativeLayout>
