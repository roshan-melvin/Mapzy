<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#202225">

    <!-- Server List (Left Sidebar) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_servers"
        android:layout_width="72dp"
        android:layout_height="match_parent"
        android:background="#121212"
        android:paddingTop="12dp"
        android:clipToPadding="false"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#2F3136">
        
        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="#36393F"
            android:elevation="4dp">
            
            <!-- Back Button (Initially hidden) -->
            <ImageView
                android:id="@+id/btn_back_channels"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_revert"
                android:visibility="gone"
                app:tint="#B9BBBE"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:id="@+id/tv_server_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Community Hub"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp"/>
        </LinearLayout>
        
        <!-- Channels List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_channels"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="8dp"
            android:layout_marginTop="56dp"/>

        <!-- Feed List (Initially Hidden) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_feed"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="8dp"
            android:layout_marginTop="56dp"
            android:layout_marginBottom="60dp"
            android:visibility="gone"
            android:background="#2F3136"/>

        <!-- Report Button for Feed (Initially Hidden) -->
        <LinearLayout
            android:id="@+id/feed_input_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:padding="12dp"
            android:background="#36393F"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_create_channel_report"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="+ Report Incident"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#5865F2"
                android:drawableStart="@android:drawable/ic_menu_camera"
                android:drawableTint="#FFFFFF"
                android:drawablePadding="8dp"
                android:paddingHorizontal="16dp"/>
        </LinearLayout>

        <!-- Thread View (Initially Hidden) -->
        <include
            android:id="@+id/thread_view_container"
            layout="@layout/layout_thread_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>
            
    </FrameLayout>

</LinearLayout>
