<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/premium_bg">

    <!-- Regions Sidebar (Left) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_regions"
        android:layout_width="72dp"
        android:layout_height="match_parent"
        android:background="@color/premium_bg"
        android:paddingTop="12dp"
        android:clipToPadding="false"/>

    <!-- Content Area (Right) -->
    <FrameLayout
        android:id="@+id/chat_content_area"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/premium_bg">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="@color/premium_surface"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/btn_back_channels"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_revert"
                android:visibility="gone"
                app:tint="#B9BBBE"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:id="@+id/tv_chat_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Select a Region"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp"/>

            <ImageView
                android:id="@+id/btn_join_region"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_input_add"
                android:background="@drawable/circle_bg"
                android:padding="8dp"
                app:tint="#43B581"/>
        </LinearLayout>

        <!-- Channel List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_chat_channels"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="8dp"
            android:layout_marginTop="56dp"/>

        <!-- Message Interface (Initially Hidden) -->
        <LinearLayout
            android:id="@+id/message_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginTop="56dp"
            android:visibility="gone"
            android:background="@color/premium_bg">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_messages"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- Message Input -->
            <LinearLayout
                android:id="@+id/input_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:background="@color/premium_surface"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btn_attach_image"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_menu_add"
                    app:tint="#B9BBBE"/>

                <EditText
                    android:id="@+id/et_message_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_border_bg"
                    android:backgroundTint="@color/premium_surface"
                    android:padding="10dp"
                    android:hint="Message..."
                    android:textColor="#FFFFFF"
                    android:textColorHint="#72767D"
                    android:maxLines="3"/>

                <ImageView
                    android:id="@+id/btn_send_message"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_send"
                    app:tint="#5865F2"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Empty State (No Regions) -->
        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:background="@color/premium_bg"
            android:elevation="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Regions Joined"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <Button
                android:id="@+id/btn_empty_join"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Join Region"
                android:layout_marginTop="16dp"/>
        </LinearLayout>

    </FrameLayout>
</LinearLayout>
