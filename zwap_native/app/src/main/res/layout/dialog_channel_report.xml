<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Report Incident"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="8dp"/>

    <!-- Channel Info -->
    <TextView
        android:id="@+id/tv_report_channel_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Posting to #accident"
        android:textSize="14sp"
        android:textColor="#5865F2"
        android:layout_marginBottom="12dp"/>

    <!-- Category (Read-only, auto-set) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_report_category"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_border_bg"
        android:backgroundTint="#F5F5F5"
        android:padding="12dp"
        android:text="Hazard"
        android:textSize="16sp"
        android:textColor="#000000"
        android:textStyle="bold"
        android:drawableStart="@android:drawable/ic_dialog_alert"
        android:drawableTint="#F44336"
        android:drawablePadding="8dp"
        android:layout_marginBottom="16dp"/>

    <!-- Description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Description"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/et_channel_description"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/rounded_border_bg"
        android:padding="12dp"
        android:hint="Describe the incident..."
        android:gravity="top"
        android:inputType="textMultiLine"
        android:layout_marginBottom="16dp"/>

    <!-- Hashtags -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hashtags"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <!-- Default hashtag (non-editable) -->
        <TextView
            android:id="@+id/tv_default_hashtag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#accident"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/circle_bg"
            android:backgroundTint="#5865F2"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_marginEnd="8dp"/>

        <!-- Additional hashtags input -->
        <EditText
            android:id="@+id/et_channel_hashtags"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/rounded_border_bg"
            android:padding="12dp"
            android:hint="Add more tags..."
            android:inputType="text"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Photo Options -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Photo"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btn_channel_take_photo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Take Photo"
            android:drawableStart="@android:drawable/ic_menu_camera"
            android:drawablePadding="8dp"
            android:backgroundTint="#E0E0E0"
            android:textColor="#000000"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_channel_add_photo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="From Gallery"
            android:drawableStart="@android:drawable/ic_menu_gallery"
            android:drawablePadding="8dp"
            android:backgroundTint="#E0E0E0"
            android:textColor="#000000"/>
    </LinearLayout>

    <ImageView
        android:id="@+id/iv_channel_photo_preview"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:layout_marginBottom="16dp"/>

    <!-- Location Selection -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Incident Location"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="8dp"/>

    <!-- Mini Map Preview -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/rounded_border_bg">

        <com.mappls.sdk.maps.MapView
            android:id="@+id/mini_map_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <!-- Center Pinpoint Marker -->
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_mylocation"
            android:tint="#F44336"
            android:layout_marginBottom="20dp"/>

        <!-- Coordinate Display Overlay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#CC000000"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/tv_map_coordinates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lat: 0.000000, Lng: 0.000000"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Drag map to position pinpoint"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Manual Coordinate Input (Optional) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/et_latitude"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/rounded_border_bg"
            android:padding="8dp"
            android:hint="Latitude"
            android:inputType="numberDecimal|numberSigned"
            android:textSize="12sp"
            android:layout_marginEnd="4dp"/>

        <EditText
            android:id="@+id/et_longitude"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/rounded_border_bg"
            android:padding="8dp"
            android:hint="Longitude"
            android:inputType="numberDecimal|numberSigned"
            android:textSize="12sp"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- Set Location Button -->
    <Button
        android:id="@+id/btn_channel_set_location"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✓ Confirm Location"
        android:drawableStart="@android:drawable/ic_menu_mylocation"
        android:drawablePadding="8dp"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_channel_cancel"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CANCEL"
            android:textColor="#666666"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_channel_submit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SUBMIT REPORT"
            android:backgroundTint="#5865F2"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>
</ScrollView>
