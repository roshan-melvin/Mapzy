<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <com.mappls.sdk.maps.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="56dp" />

    <!-- NEW ACTIVE NAVIGATION LAYOUTS -->
    <include layout="@layout/layout_nav_active_top" />
    <include layout="@layout/layout_nav_active_bottom" />
    <include layout="@layout/layout_nav_hazard_banner" />
    <!-- END NEW ACTIVE NAVIGATION LAYOUTS -->

    <!-- Music App Selector Tray — slides up above bottom bar when hamburger tapped -->
    <!-- Backdrop: full-screen transparent overlay that dismisses the tray on outside tap -->
    <View
        android:id="@+id/music_tray_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

    <include
        android:id="@+id/music_tray"
        layout="@layout/layout_music_tray"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="92dp"
        android:visibility="gone" />

    <!-- Compact Speed/Limit Widget (HUD) - Fixed position from bottom -->
    <include
        layout="@layout/widget_speed_limit"
        android:id="@+id/speed_limit_widget"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="96dp"
        android:layout_marginStart="16dp"
        android:visibility="visible" />

    <!-- AI Voice Assistant Button - MUST be declared after speedometer for z-order -->
    <!-- Elevation must be higher than speedometer (12dp) to render on top -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_ai_voice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="260dp"
        app:fabSize="normal"
        app:backgroundTint="@color/premium_surface"
        android:src="@drawable/ic_mic_premium"
        app:tint="@color/premium_red"
        app:borderWidth="0dp"
        app:elevation="16dp"
        android:elevation="16dp"
        app:shapeAppearanceOverlay="@style/App.Shape.Circle"
        android:contentDescription="AI Voice Assistant"
        android:visibility="gone" />

    <!-- Stop Navigation Button (Premium Red) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_stop_navigation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp"
        android:visibility="gone"
        app:fabSize="normal"
        app:backgroundTint="#FF3B30"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="#FFFFFF"
        app:borderWidth="0dp"
        app:elevation="8dp"
        app:shapeAppearanceOverlay="@style/App.Shape.Circle" />

    <!-- Floating Search Bar (Premium Style — single pill) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/search_card"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentTop="true"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:elevation="8dp"
        app:cardBackgroundColor="@color/premium_surface"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/premium_text_secondary" />

            <TextView
                android:id="@+id/search_trigger"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:text="Search destination..."
                android:textColor="@color/premium_text_secondary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <ImageView
                android:id="@+id/btn_voice_search"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:layout_marginEnd="4dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_mic_premium"
                app:tint="@color/premium_red" />

            <ImageView
                android:id="@+id/btn_show_nearby"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_more_outlined"
                app:tint="@color/premium_primary" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Directions Header Card (square-top / rounded-bottom — no triangular gap) -->
    <FrameLayout
        android:id="@+id/directions_header_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        android:background="@drawable/bg_directions_header_float"
        android:elevation="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:gravity="center_vertical">

            <!-- Route Line Container -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginEnd="14dp">

                <View
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:background="@drawable/bg_cyan_ring" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="22dp"
                    android:background="#48484A" />

                <View
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:background="@drawable/circle_red" />
            </LinearLayout>

            <!-- Editable Text Fields -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:divider="@android:drawable/divider_horizontal_dark"
                android:showDividers="middle">

                <!-- Origin row -->
                <LinearLayout
                    android:id="@+id/layout_origin_field"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_search_input_dark"
                    android:layout_marginBottom="4dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <TextView
                        android:id="@+id/et_origin_input"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:hint="Search origin"
                        android:text="Your location"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#8E8E93"
                        android:textSize="15sp"
                        android:background="@android:color/transparent"
                        android:singleLine="true"
                        android:focusable="true"
                        android:clickable="true" />
                </LinearLayout>

                <!-- Destination row -->
                <LinearLayout
                    android:id="@+id/layout_destination_field"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_search_input_dark"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <TextView
                        android:id="@+id/et_destination_input"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:hint="Search destination"
                        android:text="Anna Nagar"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#8E8E93"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:background="@android:color/transparent"
                        android:singleLine="true"
                        android:focusable="true"
                        android:clickable="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- Swap button -->
            <ImageView
                android:id="@+id/btn_swap_locations"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:padding="10dp"
                android:src="@android:drawable/stat_notify_sync"
                app:tint="#00E5FF"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>
    </FrameLayout>



    <!-- Directions Bottom Panel (rounded-top / square-bottom — no triangular gap) -->
    <FrameLayout
        android:id="@+id/directions_bottom_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:visibility="gone"
        android:background="@drawable/bg_nav_card_bottom"
        android:elevation="16dp">

        <LinearLayout
            android:id="@+id/directions_bottom_panel_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:orientation="vertical"
            android:padding="22dp">

            <!-- Drag handle + collapse button row -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="22dp"
                android:layout_marginBottom="0dp">

                <!-- Centered drag handle pill -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center"
                    android:background="#555555"
                    android:id="@+id/panel_drag_handle" />

                <!-- Collapse / expand chevron (end-aligned) -->
                <ImageButton
                    android:id="@+id/btn_collapse_panel"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="end|center_vertical"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/arrow_down_float"
                    android:scaleX="1.2"
                    android:scaleY="1.2"
                    app:tint="#8E8E93"
                    android:contentDescription="Collapse panel" />
            </FrameLayout>

            <!-- Top Section (Stats) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="22dp">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    
                    <TextView
                        android:id="@+id/tv_route_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 min"
                        android:textColor="#FFFFFF"
                        android:textSize="36sp"
                        android:textStyle="bold" />
                        
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        
                        <TextView
                            android:id="@+id/tv_route_distance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0 km"
                            android:textColor="#888888"
                            android:textSize="16sp" />
                            
                        <TextView
                            android:id="@+id/tv_route_eta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="ETA --:--"
                            android:textColor="#00E5FF"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Thin outlined circular progress bar -->
                <FrameLayout
                    android:id="@+id/hazard_scan_progress_container"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:visibility="gone">
                    
                    <ProgressBar
                        android:id="@+id/hazard_scan_progress"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:progressDrawable="@drawable/circular_progress"
                        android:progress="100"
                        android:max="100" />
                        
                    <TextView
                        android:id="@+id/tv_hazard_scan_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="100%"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </FrameLayout>
            </LinearLayout>

            <!-- Scanning / Briefing row (inside panel, above START) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/trip_briefing_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                app:cardBackgroundColor="#1A2A3A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@android:drawable/ic_dialog_info"
                        app:tint="#4ECDC4" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:id="@+id/tv_trip_briefing_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scanning route..."
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_trip_briefing_detail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Checking for cameras and hazards ahead"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btn_dismiss_briefing"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Actions row - Hidden during active navigation -->
            <LinearLayout
                android:id="@+id/directions_actions_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_start_navigation"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="START"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="#00E5FF"
                    app:cornerRadius="26dp"
                    app:icon="@android:drawable/ic_media_play"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconTint="#000000" />

                <ImageButton
                    android:id="@+id/btn_share_route"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_share"
                    app:tint="#8E8E93" />

                <ImageButton
                    android:id="@+id/btn_close_directions"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>


    
    <!-- Preserved IDs from previous HUD layout -->
    <LinearLayout
        android:id="@+id/route_info_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone">
        <TextView android:id="@+id/tv_distance" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tv_duration" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tv_limit" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>


    <!-- Floating Action Buttons Stack (Right Bottom) - Fixed position -->
    <LinearLayout
        android:id="@+id/fab_stack_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="96dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Hazard Toggle Button with Icon -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_toggle_osm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:fabSize="normal"
            app:backgroundTint="#40444B"
            android:src="@drawable/ic_hazard_waze"
            app:tint="#B9BBBE"
            app:borderWidth="0dp"
            app:elevation="0dp"
            android:elevation="0dp"
            android:clipToOutline="true"
            android:outlineProvider="background"
            app:shapeAppearanceOverlay="@style/App.Shape.Circle"
            app:ensureMinTouchTargetSize="false" />

        <!-- Compass Button -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_compass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:fabSize="normal"
            app:backgroundTint="#1C1C1E"
            android:src="@drawable/ic_compass_waze"
            app:tint="@null"
            app:borderWidth="0dp"
            app:elevation="0dp"
            android:elevation="0dp"
            app:shapeAppearanceOverlay="@style/App.Shape.Circle" />

        <!-- Re-center Location Button (Bottom of stack) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_recenter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="0dp"
            app:fabSize="normal"
            app:backgroundTint="#007AFF"
            android:src="@android:drawable/ic_menu_mylocation"
            app:tint="#FFFFFF"
            app:borderWidth="0dp"
            app:elevation="0dp"
            android:elevation="0dp"
            app:shapeAppearanceOverlay="@style/App.Shape.Circle" />

    </LinearLayout>

    <!-- Full-screen Search Overlay -->
    <FrameLayout
        android:id="@+id/search_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_background"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:elevation="50dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/overlay_background">

            <!-- Search Header (Premium Style) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="20dp"
                android:paddingTop="20dp"
                android:paddingRight="20dp"
                android:paddingBottom="10dp"
                android:background="@color/premium_bg">


                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_premium_input"
                    android:elevation="2dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@color/premium_text_secondary" />

                    <EditText
                        android:id="@+id/et_search_input"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:background="@null"
                        android:hint="Where to?"
                        android:textColor="@color/premium_text_main"
                        android:textColorHint="@color/premium_text_secondary"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:inputType="text"
                        android:imeOptions="actionSearch" />
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_voice_search_premium"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="12dp"
                    app:cardBackgroundColor="@color/premium_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">
                    <ImageView
                        android:id="@+id/btn_search_clear"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_mic_premium"
                        app:tint="@color/premium_red" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Dashboard (Visible when input empty) -->
            <ScrollView
                android:id="@+id/search_dashboard"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:padding="12dp"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Home/Work/Saved Shortcuts (moved to top) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="12dp"
                        android:baselineAligned="false">

                        <!-- Home -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            app:cardBackgroundColor="@color/premium_surface"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="2dp">
                            <LinearLayout
                                android:id="@+id/layout_home"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="10dp"
                                android:clickable="true"
                                android:focusable="true">
                                <FrameLayout
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="@drawable/bg_premium_icon_circle"
                                    android:layout_marginBottom="6dp">
                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:layout_gravity="center"
                                        android:src="@android:drawable/ic_menu_my_calendar"
                                        app:tint="@color/premium_primary" />
                                </FrameLayout>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textColor="@color/premium_text_main" android:textStyle="bold" android:textSize="12sp"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Work -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"
                            app:cardBackgroundColor="@color/premium_surface"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="2dp">
                            <LinearLayout
                                android:id="@+id/layout_work"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="10dp"
                                android:clickable="true"
                                android:focusable="true">
                                <FrameLayout
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="@drawable/bg_premium_icon_circle"
                                    android:layout_marginBottom="6dp">
                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:layout_gravity="center"
                                        android:src="@android:drawable/ic_lock_lock"
                                        app:tint="@color/premium_primary" />
                                </FrameLayout>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Work" android:textColor="@color/premium_text_main" android:textStyle="bold" android:textSize="12sp"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Saved -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            app:cardBackgroundColor="@color/premium_surface"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="2dp">
                            <LinearLayout
                                android:id="@+id/layout_saved"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="10dp"
                                android:clickable="true"
                                android:focusable="true">
                                <FrameLayout
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="@drawable/bg_premium_icon_circle"
                                    android:layout_marginBottom="6dp">
                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:layout_gravity="center"
                                        android:src="@android:drawable/star_on"
                                        app:tint="@color/premium_primary" />
                                </FrameLayout>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Saved" android:textColor="@color/premium_text_main" android:textStyle="bold" android:textSize="12sp"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_recent_history"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                    <!-- Recent History Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="RECENT"
                            android:textColor="@color/premium_text_secondary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/btn_clear_history"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clear All"
                            android:textColor="@color/premium_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <!-- Recent History Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/premium_surface"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingBottom="8dp"
                            android:padding="20dp">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_history"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:nestedScrollingEnabled="false" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    </LinearLayout>

                </LinearLayout>
            </ScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_search_results"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/premium_bg"
                android:padding="12dp"
                android:visibility="gone" />
            
        </LinearLayout>
    </FrameLayout>


    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_bottom_nav_curved"
        android:clipToOutline="true"
        app:itemIconSize="28dp"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:itemActiveIndicatorStyle="@style/NavActiveIndicator"
        app:itemPaddingTop="8dp"
        app:itemPaddingBottom="8dp"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_navigation_menu" />

    <!-- Fragment Container (for non-map screens) -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation"
        android:background="#000000"
        android:elevation="50dp"
        android:visibility="gone" />

    <!-- Hidden placeholders for backward compatibility with existing Kotlin code -->

    <!-- Trip Briefing Card moved inside directions_bottom_panel_container -->

    <!-- Hidden views for code compatibility -->
    <View android:id="@+id/btn_search_back" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/btn_directions" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/btn_more_history" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/btn_cat_more" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/btn_route_options" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/btn_directions_menu" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/tv_speed" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

</RelativeLayout>
