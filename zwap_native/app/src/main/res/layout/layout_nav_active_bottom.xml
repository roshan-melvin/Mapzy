<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_active_bottom_bar"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_alignParentBottom="true"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    android:visibility="gone"
    android:background="@drawable/bg_nav_active_bottom"
    android:elevation="10dp"
    android:orientation="horizontal"
    android:paddingHorizontal="8dp"
    android:gravity="center_vertical">


        <!-- Menu / Hamburger -->
        <ImageButton
            android:id="@+id/btn_nav_active_menu"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_hamburger_menu"
            app:tint="#FFFFFF" />


        <!-- Search -->
        <ImageButton
            android:id="@+id/btn_nav_active_search"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#FFFFFF" />

        <!-- Notes -->
        <ImageButton
            android:id="@+id/btn_nav_active_notes"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_note_document"
            app:tint="#FFFFFF" />

        <!-- Hazard Alert Pill — shows nearest upcoming hazard or SAFE -->
        <LinearLayout
            android:id="@+id/hazard_alert_pill"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="2.5"
            android:layout_marginEnd="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:background="@drawable/hazard_button_bg"
            android:visibility="gone">

            <!-- Icon square with dark background -->
            <FrameLayout
                android:id="@+id/hazard_pill_icon_bg"
                android:layout_width="30dp"
                android:layout_height="30dp">
                <ImageView
                    android:id="@+id/iv_hazard_pill_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_camera_outlined" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="6dp">
                <TextView
                    android:id="@+id/tv_hazard_pill_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CAMERA"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:maxLines="1" />
                <TextView
                    android:id="@+id/tv_hazard_pill_dist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="500m"
                    android:textColor="#1A1A1A"
                    android:textSize="10sp"
                    android:maxLines="1" />
            </LinearLayout>
        </LinearLayout>

        <!-- Prominent Exit Button (Red pill) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp">
            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_nav_active_exit"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="EXIT"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#FF4B4B"
                app:cornerRadius="22dp"
                app:icon="@android:drawable/ic_menu_close_clear_cancel"
                app:iconSize="20dp"
                app:iconTint="#FFFFFF"
                app:iconGravity="textStart"
                app:iconPadding="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>
</LinearLayout>
