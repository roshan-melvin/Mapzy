<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_active_bottom_bar"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_alignParentBottom="true"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    android:visibility="gone"
    android:background="@drawable/bg_nav_active_bottom"
    android:elevation="10dp"
    android:orientation="horizontal"
    android:paddingHorizontal="8dp"
    android:gravity="center_vertical">


        <!-- Menu / Hamburger -->
        <ImageButton
            android:id="@+id/btn_nav_active_menu"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_hamburger_menu"
            app:tint="#FFFFFF" />


        <!-- Search -->
        <ImageButton
            android:id="@+id/btn_nav_active_search"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#FFFFFF" />

        <!-- Notes -->
        <ImageButton
            android:id="@+id/btn_nav_active_notes"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_note_document"
            app:tint="#FFFFFF" />

        <!-- Prominent Exit Button (Red pill) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp">
            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_nav_active_exit"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="EXIT"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#FF4B4B"
                app:cornerRadius="22dp"
                app:icon="@android:drawable/ic_menu_close_clear_cancel"
                app:iconSize="20dp"
                app:iconTint="#FFFFFF"
                app:iconGravity="textStart"
                app:iconPadding="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>
</LinearLayout>
