<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_bottom_sheet_bg"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add a Report"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="24dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="2"
        android:alignmentMode="alignMargins"
        android:columnOrderPreserved="false"
        android:useDefaultMargins="true">

        <!-- Hazard -->
        <LinearLayout
            android:id="@+id/btn_report_hazard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:padding="8dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_dialog_alert"
                app:tint="#F44336"
                android:background="@drawable/circle_bg_light"
                android:padding="10dp"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hazard"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:textColor="#333333"/>
        </LinearLayout>

        <!-- Speed Camera -->
        <LinearLayout
            android:id="@+id/btn_report_camera"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:padding="8dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="#2196F3"
                android:background="@drawable/circle_bg_light"
                android:padding="10dp"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Speed Cam"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:textColor="#333333"/>
        </LinearLayout>

        <!-- Police -->
        <LinearLayout
            android:id="@+id/btn_report_police"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:padding="8dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_secure"
                app:tint="#3F51B5"
                android:background="@drawable/circle_bg_light"
                android:padding="10dp"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Police"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:textColor="#333333"/>
        </LinearLayout>

        <!-- Traffic -->
        <LinearLayout
            android:id="@+id/btn_report_traffic"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:padding="8dp"
            android:layout_marginTop="16dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_popup_sync"
                app:tint="#FF9800"
                android:background="@drawable/circle_bg_light"
                android:padding="10dp"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Traffic"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:textColor="#333333"/>
        </LinearLayout>

        <!-- Map Issue -->
        <LinearLayout
            android:id="@+id/btn_report_map"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:padding="8dp"
            android:layout_marginTop="16dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_mapmode"
                app:tint="#4CAF50"
                android:background="@drawable/circle_bg_light"
                android:padding="10dp"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Map Issue"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:textColor="#333333"/>
        </LinearLayout>

    </GridLayout>

    <!-- Add Photo Button -->
    <LinearLayout
        android:id="@+id/btn_add_photo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:background="@drawable/rounded_border_bg"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/iv_photo_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_camera"
            app:tint="#666666"/>
        
        <TextView
            android:id="@+id/tv_add_photo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Photo"
            android:textColor="#666666"
            android:layout_marginStart="8dp"
            android:textStyle="bold"/>
    </LinearLayout>
    
    <ImageView
        android:id="@+id/iv_photo_preview"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_marginTop="12dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:background="#EEEEEE"/>

    <Button
        android:id="@+id/btn_cancel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancel"
        android:backgroundTint="#EEEEEE"
        android:textColor="#666666"
        android:layout_marginTop="24dp"
        style="@style/Widget.MaterialComponents.Button.TextButton"/>
</LinearLayout>
