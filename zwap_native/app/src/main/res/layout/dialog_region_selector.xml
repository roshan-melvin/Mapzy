<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/premium_surface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Join Regional Chat"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select your region to connect with local drivers"
        android:textSize="14sp"
        android:textColor="#B9BBBE"
        android:layout_marginBottom="24dp"/>

    <!-- Country Spinner -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Country"
        android:textSize="14sp"
        android:textColor="#B9BBBE"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinner_country"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_border_bg_dark"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <!-- State Spinner -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="State / Region"
        android:textSize="14sp"
        android:textColor="#B9BBBE"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinner_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_border_bg_dark"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <!-- City Spinner -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="City / Area"
        android:textSize="14sp"
        android:textColor="#B9BBBE"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinner_city"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_border_bg_dark"
        android:padding="12dp"
        android:layout_marginBottom="24dp"/>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_region_cancel"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CANCEL"
            android:textColor="#B9BBBE"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_region_join"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JOIN CHAT"
            android:backgroundTint="#5865F2"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>
