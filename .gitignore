# ==========================================
# ZWAP NAVIGATION APP - Git Ignore
# ==========================================

# ==========================================
# SENSITIVE FILES - API Keys & Secrets
# ==========================================
config.js
**/local.properties
**/key.properties
**/.env
**/.env.local
**/.env.production
**/.env.development

# Mappls SDK Keys (if stored in separate files)
mappls_keys.txt
api_keys.txt

# ==========================================
# ANDROID NATIVE APP (zwap_native/)
# ==========================================

# Gradle files
.gradle/
zwap_native/.gradle/
zwap_native/build/
zwap_native/app/build/
zwap_native/local.properties
zwap_native/gradle.properties.local

# Android Studio / IntelliJ IDEA
zwap_native/.idea/
zwap_native/*.iml
zwap_native/.idea/workspace.xml
zwap_native/.idea/tasks.xml
zwap_native/.idea/gradle.xml
zwap_native/.idea/assetWizardSettings.xml
zwap_native/.idea/dictionaries
zwap_native/.idea/libraries
zwap_native/.idea/caches
zwap_native/.idea/modules.xml
zwap_native/.idea/navEditor.xml

# Android build outputs
zwap_native/app/release/
zwap_native/app/debug/
zwap_native/*.apk
zwap_native/*.aab
zwap_native/*.ap_
zwap_native/*.dex

# Heap dumps and profiling files
zwap_native/*.hprof
*.hprof
java_pid*.hprof

# Signing files
zwap_native/*.jks
zwap_native/*.keystore
zwap_native/key.properties

# Captures folder
zwap_native/captures/
zwap_native/.externalNativeBuild/
zwap_native/.cxx/

# Google Services
zwap_native/google-services.json

# ==========================================
# FLUTTER APP (DELETED - Keep for reference)
