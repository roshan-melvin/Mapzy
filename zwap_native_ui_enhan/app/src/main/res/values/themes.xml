<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Zwap" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Mapzy Colors -->
        <item name="colorPrimary">@color/mapzy_blue</item>
        <item name="colorSecondary">@color/mapzy_blue</item>
        <item name="colorTertiary">@color/mapzy_blue</item>
        <item name="android:windowBackground">@color/mapzy_black</item>
        <item name="android:statusBarColor">@color/mapzy_black</item>
        <item name="android:navigationBarColor">@color/mapzy_black</item>
    </style>

    <style name="BottomSheetDialogTheme" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <!-- Material 3 Bottom Navigation Active Indicator — soft rounded pill -->
    <style name="NavActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#5B87CEEB</item>
        <item name="android:width">56dp</item>
        <item name="android:height">32dp</item>
        <item name="shapeAppearance">@style/NavPillShape</item>
    </style>

    <style name="NavPillShape" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Legacy indicator styles (kept for compatibility) -->
    <style name="App.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#5B87CEEB</item>
        <item name="marginHorizontal">16dp</item>
        <item name="shapeAppearance">@style/App.Shape.Circle</item>
    </style>

    <style name="App.Shape.Circle" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
