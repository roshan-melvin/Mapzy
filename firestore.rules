rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Reports (Hierarchy: reports/{channel}/threads/{reportId})
    match /reports/{channel} {
      // Required for repository.submitReport() to create the channel document
      // and for repository.getFeedReports() to list across channels
      allow read, write: if request.auth != null;
      
      match /threads/{reportId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if true;
        allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || resource.data.reportedBy == request.auth.uid);
      }
    }
    
    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Chat
    match /chat/{regionId} {
      allow read, write: if request.auth != null;
      
      match /threads/{threadId} {
         allow read, write: if request.auth != null;
         
         match /messages/{messageId} {
            allow read, write: if request.auth != null;
         }
      }
    }
  }
}
